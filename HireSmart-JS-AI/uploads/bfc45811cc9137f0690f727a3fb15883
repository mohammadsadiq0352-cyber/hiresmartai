#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>

int main(int argc, char *argv[])
{
    char ch;
    int fd;

    if(argc < 2) {
        printf("Usage: %s filename\n", argv[0]);
        return 1;
    }

    fd = open(argv[1], O_RDONLY);

    if(fd == -1)
    {
        printf("File not opened\n");
        return 1;
    }

    printf("No of arguments: %d\n", argc);

    while(read(fd, &ch, 1) > 0)
        putchar(ch);

    close(fd);
    return 0;
}
